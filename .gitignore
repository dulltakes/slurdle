# Ignore node_modules directory
node_modules/

# Ignore npm debug log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore .env files
.env
.env.*.local

# Ignore Parcel cache
.parcel-cache/
.cache/

# Ignore dist directory (output of the build process)
dist/

# Ignore WebStorm/IntelliJ IDEA project files
.idea/

# Ignore MacOS specific files
.DS_Store

# Ignore temporary files and directories
tmp/
temp/

# Ignore log files
*.log

# Ignore build artifacts
build/

# Ignore coverage reports
coverage/

# Ignore VSCode settings (if you use VSCode occasionally)
.vscode/

# Ignore local environment settings
local.env

# Ignore package lock files (if using npm)
package-lock.json
yarn.lock